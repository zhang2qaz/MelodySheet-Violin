{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "api",
      "runtimeExecutable": "apps/api/.venv/bin/uvicorn",
      "runtimeArgs": ["main:app", "--port", "8000", "--app-dir", "apps/api"],
      "port": 8000
    },
    {
      "name": "web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "apps/web", "run", "dev"],
      "port": 3000
    }
  ]
}
