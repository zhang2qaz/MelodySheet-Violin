# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_MAX_UPLOAD_MB=50

# Backend
MELODYSHEET_STORAGE_PATH=../../storage
MELODYSHEET_MAX_UPLOAD_BYTES=52428800
MELODYSHEET_ALLOWED_FILE_TYPES=mp3,wav,m4a
MELODYSHEET_AUTO_PROCESS=true
MELODYSHEET_CORS_ORIGINS=http://localhost:3000
# Optional: override Basic Pitch model path, for example an ONNX model on Linux.
MELODYSHEET_BASIC_PITCH_MODEL_PATH=
