# 前端
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_MAX_UPLOAD_MB=50

# 后端
MELODYSHEET_STORAGE_PATH=../../storage
MELODYSHEET_MAX_UPLOAD_BYTES=52428800
MELODYSHEET_ALLOWED_FILE_TYPES=mp3,wav,m4a
MELODYSHEET_AUTO_PROCESS=true
MELODYSHEET_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# 可选：启用 Demucs 人声/伴奏二分离。默认关闭；需要本机安装 demucs。
MELODYSHEET_ENABLE_DEMUCS_SEPARATION=false
# 可选：覆盖 Basic Pitch 模型路径，例如 Linux 上的 ONNX 模型。
MELODYSHEET_BASIC_PITCH_MODEL_PATH=
